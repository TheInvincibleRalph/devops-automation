pipeline {
    agent any
    
    environment {
        AWS_REGION     = "us-east-2"
        AWS_ACCOUNT_ID = "681504525746" // Added this
        IMAGE_REPO     = "php-ecommerce-app"
        ECR_URL        = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_REPO}"
    }
    /*
    stages {
        stage('Pre-Build: PHP Linting') {
            steps {
                sh "find ./app -name '*.php' -print0 | xargs -0 -n1 php -l"
            }
        }
        */

        stage('Docker Build') {
            steps {
                sh "docker build -t ${IMAGE_REPO}:${GIT_COMMIT} ./app"
            }
        }
        
        stage('Security Scan') {
            steps {
                sh "trivy image --severity HIGH,CRITICAL ${IMAGE_REPO}:${GIT_COMMIT}"
            }
        }
        
        stage('Push to AWS ECR') {
            steps {
                withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                    
                    // Tag and push both Commit ID and Latest
                    sh "docker tag ${IMAGE_REPO}:${GIT_COMMIT} ${ECR_URL}:${GIT_COMMIT}"
                    sh "docker tag ${IMAGE_REPO}:${GIT_COMMIT} ${ECR_URL}:latest"
                    
                    sh "docker push ${ECR_URL}:${GIT_COMMIT}"
                    sh "docker push ${ECR_URL}:latest"
                }
            }
        }
        
        stage('Deploy to App EC2 (via SSM)') {
            steps {
                script {
                    withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                        // Find the Instance ID dynamically
                        def INSTANCE_ID = sh(script: "aws ec2 describe-instances --region ${AWS_REGION} --filters 'Name=tag:Name,Values=application' 'Name=instance-state-name,Values=running' --query 'Reservations[0].Instances[0].InstanceId' --output text", returnStdout: true).trim()

                        if (INSTANCE_ID == "None" || INSTANCE_ID == "") {
                            error "No running EC2 instance found with tag Name=application"
                        }

                        sh """
                        aws ssm send-command \
                            --region ${AWS_REGION} \
                            --instance-ids "${INSTANCE_ID}" \
                            --document-name "AWS-RunShellScript" \
                            --parameters 'commands=[
                                "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com",
                                "docker pull ${ECR_URL}:latest",
                                "docker stop php-ecommerce-app || true",
                                "docker rm php-ecommerce-app || true",
                                "docker run -d --name php-ecommerce-app -p 80:80 ${ECR_URL}:latest"
                            ]'
                        """
                    }
                }
            }
        }
    }
    
    post {
        always {
            sh "docker system prune -af"
        }
        failure {
            echo "Pipeline failed! Check the Console Output."
        }
        success {
            echo "Deployment successful!"
        }
    }
